@startuml NamingCheck_REST_API_Components
title C4 Level 3 (Component) - REST API (current backend MVP)

!include <C4/C4_Component>

LAYOUT_TOP_DOWN()

Person(client, "Client", "UI, curl, integrator")

Container_Boundary(rest_api_boundary, "naming-check-backend (FastAPI)") {
  Component(http_routes, "HTTP Route Handlers", "Python", "logo-similarity search+preview, text-similarity search, health, stage2 webhook")
  Component(visual_client, "Visual Sidecar Client", "httpx", "POST multipart to /similarity; GET /asset for preview bytes")
  Component(text_client, "Text Sidecar Client", "httpx", "POST JSON to /similarity")
  Component(webhook_uc, "WebhookCallbackProcessingUseCase", "Python", "Accepts Stage2 batches; 202 Accepted")
}

Container(visual_sidecar, "visual-model-service", "FastAPI", "CPU similarity + asset files")
Container(text_sidecar, "text-model-service", "FastAPI", "CPU text similarity")

Rel_Down(client, http_routes, "HTTPS /api/v1/...", "HTTPS/JSON or multipart")
Rel_Down(http_routes, visual_client, "Forward logo search / preview")
Rel_Down(http_routes, text_client, "Forward text search")
Rel_Down(http_routes, webhook_uc, "POST .../webhooks/stage2-results")

Rel_Down(visual_client, visual_sidecar, "HTTP internal", "Docker network")
Rel_Down(text_client, text_sidecar, "HTTP internal", "Docker network")

note right of http_routes
  No in-process Stage1 orchestrator
  or job queue in this codebase path.
end note

SHOW_LEGEND()

@enduml
